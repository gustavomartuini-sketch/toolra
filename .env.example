# Toolra — Environment Variables
# Add these in Vercel → Settings → Environment Variables

# xAI (Grok) API key
# Get from: https://console.x.ai/
XAI_API_KEY=your_xai_api_key_here

# ExchangeRate API key
# Get from: https://www.exchangerate-api.com/ (free tier: 1500 req/month)
EXCHANGERATE_API_KEY=your_exchangerate_api_key_here

# Optional: Pro tier secret token
# Set any random string — users with this token get 100 req/day instead of 10
# PRO_SECRET=your_secret_pro_token_here
